{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "architect",
  "instructions": [
    ".opencode/rules/global.md",
    ".opencode/rules/core-standards.md"
  ],
  "provider": {
    "opencode": {},
    "opencode-go": {}
  },
  "agent": {
    "architect": {
      "mode": "primary",
      "model": "opencode-go/qwen3.6-plus",
      "temperature": 0.2,
      "color": "#7c3aed",
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "task": {
          "developer": "allow",
          "context": "allow",
          "guardian": "allow",
          "analyst": "allow",
          "designer": "allow"
        }
      }
    },
    "context": {
      "mode": "all",
      "model": "opencode/gemini-3-flash",
      "temperature": 0.1,
      "color": "#f59e0b",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "guardian": {
      "mode": "all",
      "model": "opencode-go/deepseek-v4-flash",
      "temperature": 0.1,
      "color": "#ef4444",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "flake8 *": "allow",
          "npm run lint*": "allow",
          "npx eslint *": "allow",
          "ruff check *": "allow"
        }
      }
    },
    "analyst": {
      "mode": "all",
      "model": "opencode/claude-sonnet-4-6",
      "temperature": 0.1,
      "color": "#0ea5e9",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "designer": {
      "mode": "all",
      "model": "opencode-go/minimax-m2.7",
      "temperature": 0.4,
      "color": "#ec4899",
      "permission": {
        "edit": "allow",
        "bash": "deny",
        "webfetch": "allow"
      }
    }
  }
}

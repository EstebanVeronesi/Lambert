# =============================================================================
# VARIABLES DE ENTORNO - Lambert Backend
# =============================================================================
# Copiar este archivo a .env y completar con valores reales
# NUNCA commitear el archivo .env al repositorio

# Base de Datos (PostgreSQL)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=lambert
DB_PASSWORD=tu_password_seguro_aqui
DB_PORT=5432

# Servidor
PORT=3000

# Seguridad (OBLIGATORIAS - el servidor no arranca sin ellas)
SECRET_JWT_KEY=tu_clave_jwt_segura_minimo_32_caracteres_aqui
SALT_ROUNDS=10

# CORS - Orígenes permitidos (separar múltiples con coma)
# Ejemplo: http://localhost:4200,https://miapp.com
CORS_ORIGIN=http://localhost:4200
